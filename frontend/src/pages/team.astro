---
import Layout from '../layouts/Layout.astro';
import PokemonCard from '../components/PokemonCard.astro';

// Fetch all local JSON files
const pokemonFiles = import.meta.glob('../../../data/champions/pokemon/**/*.json', { eager: true });
const allPokemons = Object.values(pokemonFiles).map((file: any) => file.default);
import hiddenForms from "../../../data/hidden_forms.json";
import excludedForms from '../../../data/excluded_forms.json';

const validPokemons = allPokemons.filter(p => {
	if (p.form.includes('-gmax')) return false;
	if (excludedForms.includes(p.form)) return false;
		if (hiddenForms.includes(p.form)) return false;
	if (p.id === 25 && p.form !== 'pikachu') return false; // Pikachu forms exclusion
	return true;
});
let pokemons = validPokemons;
pokemons.sort((a, b) => {
	if (a.id !== b.id) return a.id - b.id;
	if (a.form === a.name) return -1;
	if (b.form === b.name) return 1;
	return a.form.localeCompare(b.form);
});

const statsMap = {};
for (const p of allPokemons) {
	statsMap[`${p.id}_${p.form}`] = p.stats;
}

const allMovesFiles = import.meta.glob('../../../data/moves/*.json', { eager: true });
const movesNameMap = {};
Object.values(allMovesFiles).forEach((file: any) => {
  const moveData = file.default;
  movesNameMap[moveData.id] = {
    en: moveData.name_en || moveData.name,
    fr: moveData.name_fr || moveData.name,
    type: moveData.type_name || 'normal',
    desc_en: moveData.description_en || '',
    desc_fr: moveData.description_fr || ''
  };
});

import naturesData from '../../public/data/natures.json';
import itemsData from '../../public/data/items.json';
import abilitiesData from '../../public/data/abilities.json';
const pokemonNameMap = {};
allPokemons.forEach(p => {
  pokemonNameMap[`${p.id}-${p.form}`] = { 
    name_en: p.name_en || p.name, 
    name_fr: p.name_fr || p.name_en || p.name 
  };
});
---

<Layout title="My Team | Pokédex">
  <div class="team-page" id="team-page-container" data-pokemon-names={encodeURIComponent(JSON.stringify(pokemonNameMap))} data-moves={encodeURIComponent(JSON.stringify(movesNameMap))} data-natures={encodeURIComponent(JSON.stringify(naturesData))} data-items={encodeURIComponent(JSON.stringify(itemsData))} data-abilities={encodeURIComponent(JSON.stringify(abilitiesData))}>
    <header class="page-header">
      <h1 data-i18n="my_team">My Pokémon Team</h1>
      <p data-i18n="create_manage_teams">Create and manage your dream teams! (Maximum 6 Pokémon per team)</p>
    </header>

    <!-- Multiple Teams Selector -->
    <div class="team-selector-container">
      <div id="team-list" class="team-list">
        <!-- Populated by JS -->
      </div>
      <button id="create-team-btn" class="create-team-btn glass-panel" data-i18n-title="create_new_team" title="Create new team">
        <span>+</span>
      </button>
    </div>

    <div class="team-container-wrapper" id="capture-area">
      <div class="export-header hidden" id="export-header">
        <h2 id="export-team-name">My Champion Team</h2>
        <div class="export-logo">PokeCraft</div>
      </div>

      <main class="team-circle-grid" id="team-grid">
        <!-- Populated by JS -->
      </main>

      <div class="stats-toggle-container hidden" id="stats-toggle-container">
        <button id="toggle-stats-btn" class="toggle-stats-btn glass-panel" data-i18n="show_stats">
          Show statistics ▼
        </button>
      </div>

      <div id="team-stats-grid" class="team-stats-grid hidden-collapsible">
        <!-- Populated by JS -->
      </div>
      
      <div id="empty-state" class="empty-state hidden">
        <h2 data-i18n="empty_team_title">Your team is empty!</h2>
        <p data-i18n="empty_team_desc">Add your favorite Pokémon from the list below.</p>
      </div>
    </div>

    <div class="team-pokedex-section">
      <h2 class="section-title" data-i18n="add_pokemon">Add Pokémon</h2>
      
      <div class="pokedex-filters">
        <div class="type-filter-buttons" id="pokedex-type-filter">
          <button class="type-btn active" data-type="all" data-i18n="all_types">All</button>
          <button class="type-btn bg-normal" data-type="normal" data-i18n="type_normal">Normal</button>
          <button class="type-btn bg-fire" data-type="fire" data-i18n="type_fire">Fire</button>
          <button class="type-btn bg-water" data-type="water" data-i18n="type_water">Water</button>
          <button class="type-btn bg-grass" data-type="grass" data-i18n="type_grass">Grass</button>
          <button class="type-btn bg-electric" data-type="electric" data-i18n="type_electric">Electric</button>
          <button class="type-btn bg-ice" data-type="ice" data-i18n="type_ice">Ice</button>
          <button class="type-btn bg-fighting" data-type="fighting" data-i18n="type_fighting">Fighting</button>
          <button class="type-btn bg-poison" data-type="poison" data-i18n="type_poison">Poison</button>
          <button class="type-btn bg-ground" data-type="ground" data-i18n="type_ground">Ground</button>
          <button class="type-btn bg-flying" data-type="flying" data-i18n="type_flying">Flying</button>
          <button class="type-btn bg-psychic" data-type="psychic" data-i18n="type_psychic">Psychic</button>
          <button class="type-btn bg-bug" data-type="bug" data-i18n="type_bug">Bug</button>
          <button class="type-btn bg-rock" data-type="rock" data-i18n="type_rock">Rock</button>
          <button class="type-btn bg-ghost" data-type="ghost" data-i18n="type_ghost">Ghost</button>
          <button class="type-btn bg-dragon" data-type="dragon" data-i18n="type_dragon">Dragon</button>
          <button class="type-btn bg-dark" data-type="dark" data-i18n="type_dark">Dark</button>
          <button class="type-btn bg-steel" data-type="steel" data-i18n="type_steel">Steel</button>
          <button class="type-btn bg-fairy" data-type="fairy" data-i18n="type_fairy">Fairy</button>
          <button class="type-btn bg-dark" style="background: linear-gradient(135deg, #a040a0 0%, #303030 100%); color: white;" data-type="mega">MEGA</button>
        </div>
      </div>

      <div class="pokemon-grid">
        {pokemons.map((pokemon) => (
          <PokemonCard pokemon={pokemon} />
        ))}
      </div>
    </div>

    <!-- Configuration Modal -->
    <div id="config-modal" class="modal-overlay hidden">
      <div class="modal-content glass-panel">
        <div class="modal-header">
          <h2 id="config-modal-title">Configure Pokémon</h2>
          <button id="close-config-btn" class="close-btn">&times;</button>
        </div>
        <div class="modal-body">
          <input type="hidden" id="config-pokemon-id" />
          <input type="hidden" id="config-pokemon-form" />

          <div class="config-section">
            <h3 data-i18n="nature">Nature</h3>
            <div class="custom-select-wrapper" id="nature-select-wrapper">
              <div class="custom-select-trigger" id="nature-select-trigger">
                <div id="nature-select-display" class="item-select-display">
                  <span>-- Select Nature --</span>
                </div>
                <span class="custom-select-arrow">▼</span>
              </div>
              <div class="custom-select-dropdown hidden" id="nature-select-dropdown">
                <div class="custom-select-options" id="nature-options-list">
                  <!-- Populated by JS -->
                </div>
              </div>
            </div>
            <input type="hidden" id="config-nature-hidden" value="25">
          </div>

          <div class="config-section">
            <h3 data-i18n="abilities">Ability</h3>
            <div class="custom-select-wrapper" id="ability-select-wrapper">
              <div class="custom-select-trigger" id="ability-select-trigger">
                <div id="ability-select-display" class="item-select-display">
                  <span>-- Select Ability --</span>
                </div>
                <span class="custom-select-arrow">▼</span>
              </div>
              <div class="custom-select-dropdown hidden" id="ability-select-dropdown">
                <div class="custom-select-options" id="ability-options-list">
                  <!-- Populated by JS -->
                </div>
              </div>
            </div>
            <input type="hidden" id="config-ability-hidden" value="">
          </div>

          <div class="config-section">
            <h3 data-i18n="held_item">Held Item</h3>
            <div class="custom-select-wrapper" id="item-select-wrapper">
              <div class="custom-select-trigger" id="item-select-trigger">
                <div id="item-select-display" class="item-select-display">
                  <span data-i18n="no_item">-- No Item --</span>
                </div>
                <span class="custom-select-arrow">▼</span>
              </div>
              <div class="custom-select-dropdown hidden" id="item-select-dropdown">
                <div class="custom-select-search">
                  <input type="text" id="item-search-input" data-i18n-placeholder="search_item" placeholder="Search item..." autocomplete="off">
                </div>
                <div class="custom-select-options" id="item-options-list">
                  <!-- Populated by JS -->
                </div>
              </div>
            </div>
            <input type="hidden" id="config-item-hidden" value="">
          </div>

          <div class="config-section">
            <h3 data-i18n="moves">Moves (Max 4)</h3>
            <div class="moves-grid">
              <div class="custom-select-wrapper" id="move-select-wrapper-1">
                <div class="custom-select-trigger" id="move-select-trigger-1" data-index="1">
                  <div id="move-select-display-1" class="item-select-display">
                    <span data-i18n="select_move_1">-- Select Move 1 --</span>
                  </div>
                  <span class="custom-select-arrow">▼</span>
                </div>
                <div class="custom-select-dropdown hidden" id="move-select-dropdown-1">
                  <div class="custom-select-search">
                    <input type="text" id="move-search-input-1" data-i18n-placeholder="search_move" placeholder="Search move..." autocomplete="off">
                  </div>
                  <div class="custom-select-options" id="move-options-list-1"></div>
                </div>
                <input type="hidden" id="config-move-1-hidden" value="">
              </div>
              <div class="custom-select-wrapper" id="move-select-wrapper-2">
                <div class="custom-select-trigger" id="move-select-trigger-2" data-index="2">
                  <div id="move-select-display-2" class="item-select-display">
                    <span data-i18n="select_move_2">-- Select Move 2 --</span>
                  </div>
                  <span class="custom-select-arrow">▼</span>
                </div>
                <div class="custom-select-dropdown hidden" id="move-select-dropdown-2">
                  <div class="custom-select-search">
                    <input type="text" id="move-search-input-2" data-i18n-placeholder="search_move" placeholder="Search move..." autocomplete="off">
                  </div>
                  <div class="custom-select-options" id="move-options-list-2"></div>
                </div>
                <input type="hidden" id="config-move-2-hidden" value="">
              </div>
              <div class="custom-select-wrapper" id="move-select-wrapper-3">
                <div class="custom-select-trigger" id="move-select-trigger-3" data-index="3">
                  <div id="move-select-display-3" class="item-select-display">
                    <span data-i18n="select_move_3">-- Select Move 3 --</span>
                  </div>
                  <span class="custom-select-arrow">▼</span>
                </div>
                <div class="custom-select-dropdown hidden" id="move-select-dropdown-3">
                  <div class="custom-select-search">
                    <input type="text" id="move-search-input-3" data-i18n-placeholder="search_move" placeholder="Search move..." autocomplete="off">
                  </div>
                  <div class="custom-select-options" id="move-options-list-3"></div>
                </div>
                <input type="hidden" id="config-move-3-hidden" value="">
              </div>
              <div class="custom-select-wrapper" id="move-select-wrapper-4">
                <div class="custom-select-trigger" id="move-select-trigger-4" data-index="4">
                  <div id="move-select-display-4" class="item-select-display">
                    <span data-i18n="select_move_4">-- Select Move 4 --</span>
                  </div>
                  <span class="custom-select-arrow">▼</span>
                </div>
                <div class="custom-select-dropdown hidden" id="move-select-dropdown-4">
                  <div class="custom-select-search">
                    <input type="text" id="move-search-input-4" data-i18n-placeholder="search_move" placeholder="Search move..." autocomplete="off">
                  </div>
                  <div class="custom-select-options" id="move-options-list-4"></div>
                </div>
                <input type="hidden" id="config-move-4-hidden" value="">
              </div>
            </div>
          </div>

          <div class="config-section">
            <h3><span data-i18n="ev_stats">EV Stats</span> (Total: <span id="ev-total">0</span>/66)</h3>
            <p class="ev-hint" data-i18n="ev_hint">Max 32 points per stat.</p>
            <div class="ev-sliders">
              <div class="ev-row">
                <label><span data-i18n="stat_hp">HP</span> (<span id="ev-val-hp">0</span>)<span id="ev-final-hp" class="ev-final-stat"></span></label>
                <input type="range" id="ev-hp" class="ev-slider" min="0" max="32" value="0" />
              </div>
              <div class="ev-row">
                <label><span data-i18n="stat_attack">Attack</span> (<span id="ev-val-attack">0</span>)<span id="ev-final-attack" class="ev-final-stat"></span></label>
                <input type="range" id="ev-slider-attack" class="ev-slider" data-stat="attack" min="0" max="32" value="0" />
              </div>
              <div class="ev-row">
                <label><span data-i18n="stat_defense">Defense</span> (<span id="ev-val-defense">0</span>)<span id="ev-final-defense" class="ev-final-stat"></span></label>
                <input type="range" id="ev-slider-defense" class="ev-slider" data-stat="defense" min="0" max="32" value="0" />
              </div>
              <div class="ev-row">
                <label><span data-i18n="stat_special-attack">Sp. Atk</span> (<span id="ev-val-special-attack">0</span>)<span id="ev-final-special-attack" class="ev-final-stat"></span></label>
                <input type="range" id="ev-slider-special-attack" class="ev-slider" data-stat="special-attack" min="0" max="32" value="0" />
              </div>
              <div class="ev-row">
                <label><span data-i18n="stat_special-defense">Sp. Def</span> (<span id="ev-val-special-defense">0</span>)<span id="ev-final-special-defense" class="ev-final-stat"></span></label>
                <input type="range" id="ev-slider-special-defense" class="ev-slider" data-stat="special-defense" min="0" max="32" value="0" />
              </div>
              <div class="ev-row">
                <label><span data-i18n="stat_speed">Speed</span> (<span id="ev-val-speed">0</span>)<span id="ev-final-speed" class="ev-final-stat"></span></label>
                <input type="range" id="ev-slider-speed" class="ev-slider" data-stat="speed" min="0" max="32" value="0" />
              </div>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button id="save-config-btn" class="save-btn glass-panel" data-i18n="save">Save Configuration</button>
        </div>
      </div>
    </div>

    <!-- Export Menu -->
    <div class="export-menu-container">
      <div id="export-options" class="export-options hidden">
        <button id="export-png-btn" class="export-btn png-btn" title="Export as PNG">
          <span>📸</span> PNG
        </button>
        <button id="export-pdf-btn" class="export-btn pdf-btn" title="Export as PDF">
          <span>📄</span> PDF
        </button>
      </div>
      <button id="export-main-btn" class="export-main-btn" data-i18n="export">
        EXPORT
      </button>
    </div>
  </div>

  <script is:inline define:vars={{ statsMap }}>
    window.pokemonStatsMap = statsMap;
  </script>

  <script>
    import { getAllTeams, getActiveTeam, setActiveTeam, createTeam, deleteTeam, removeFromTeam, renameActiveTeam, updatePokemonConfig, getActiveTeamId } from '../scripts/teamStore.js';
    import { getLang, translateDOM, t } from '../scripts/langStore.js';
    import html2canvas from 'html2canvas';
    import { jsPDF } from 'jspdf';

    const teamGrid = document.getElementById('team-grid');
    const teamStatsGrid = document.getElementById('team-stats-grid');
    const toggleStatsBtn = document.getElementById('toggle-stats-btn');
    const statsToggleContainer = document.getElementById('stats-toggle-container');
    const emptyState = document.getElementById('empty-state');
    const captureArea = document.getElementById('capture-area');
    const exportHeader = document.getElementById('export-header');
    const exportTeamName = document.getElementById('export-team-name');
    const teamListEl = document.getElementById('team-list');
    const createTeamBtn = document.getElementById('create-team-btn');

    const btnExportMain = document.getElementById('export-main-btn');
    const exportOptions = document.getElementById('export-options');
    const btnPng = document.getElementById('export-png-btn');
    const btnPdf = document.getElementById('export-pdf-btn');

    const pageContainer = document.getElementById('team-page-container');
    const globalPokemonNamesMap = JSON.parse(decodeURIComponent(pageContainer?.dataset.pokemonNames || '{}'));
    const globalMovesNameMap = JSON.parse(decodeURIComponent(pageContainer?.dataset.moves || '{}'));
    const globalNaturesMap = JSON.parse(decodeURIComponent(pageContainer?.dataset.natures || '{}'));
    const globalItemsMap = JSON.parse(decodeURIComponent(pageContainer?.dataset.items || '{}'));
    const globalAbilitiesMap = JSON.parse(decodeURIComponent(pageContainer?.dataset.abilities || '{}'));
    const validItems = Object.values(globalItemsMap).filter((itm: any) => itm.sprite || itm.effect_en);

    // Handle translations
    window.addEventListener('lang-changed', () => {
      translateDOM();
      renderUI();
    });

    function renderTeamList() {
      const teams = getAllTeams();
      const activeTeam = getActiveTeam();

      if (!teamListEl) return;

      teamListEl.innerHTML = teams.map(team => {
        const isActive = team.id === activeTeam.id;
        return `
          <div class="team-tab ${isActive ? 'active' : ''}" data-id="${team.id}">
            <span class="team-name">${team.name}</span>
            <button class="rename-team-btn" data-id="${team.id}" data-i18n-title="rename_team" title="${t('rename_team')}">✏️</button>
            <span class="team-count">(${team.members.length}/6)</span>
            ${teams.length > 1 ? `<button class="delete-team-btn" data-id="${team.id}" title="Delete team">×</button>` : ''}
          </div>
        `;
      }).join('');

      // Add listeners for tabs
      document.querySelectorAll('.team-tab').forEach(tab => {
        tab.addEventListener('click', (e) => {
          if ((e.target as HTMLElement).closest('button')) return; // Ignore clicks on buttons inside tab
          const id = (e.currentTarget as HTMLElement).dataset.id;
          setActiveTeam(id);
          renderUI();
        });
      });

      document.querySelectorAll('.rename-team-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const id = (e.currentTarget as HTMLElement).dataset.id;
          const team = teams.find(t => t.id === id);
          if (team) {
            const newName = prompt("New team name:", team.name);
            if (newName && newName.trim() !== "" && newName.trim() !== team.name) {
              setActiveTeam(id);
              renameActiveTeam(newName.trim());
              renderUI();
            }
          }
        });
      });

      document.querySelectorAll('.delete-team-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const id = (e.target as HTMLElement).dataset.id;
          if (confirm('Are you sure you want to delete this team?')) {
            deleteTeam(id);
            renderUI();
          }
        });
      });
    }

    function renderTeamGrid() {
      if (!teamGrid) return;
      const activeTeam = getActiveTeam();
      const team = activeTeam.members;
      
      if (team.length === 0) {
        teamGrid.innerHTML = '';
        if (teamStatsGrid) teamStatsGrid.innerHTML = '';
        teamGrid.classList.add('hidden');
        if (statsToggleContainer) statsToggleContainer.classList.add('hidden');
        if (emptyState) emptyState.classList.remove('hidden');
        if (btnExportMain) btnExportMain.style.display = 'none';
        return;
      }

      if (emptyState) emptyState.classList.add('hidden');
      teamGrid.classList.remove('hidden');
      if (statsToggleContainer) statsToggleContainer.classList.remove('hidden');
      if (btnExportMain) btnExportMain.style.display = 'block';

      teamGrid.innerHTML = team.map(pokemon => {
        const primaryType = pokemon.types[0] || 'normal';
        const currentLang = getLang();
        
        const names = globalPokemonNamesMap[`${pokemon.id}-${pokemon.form}`] || {};
        const nameEn = names.name_en || pokemon.name_en || pokemon.name;
        const nameFr = names.name_fr || pokemon.name_fr || nameEn;
        
        let formattedNameEn = nameEn.charAt(0).toUpperCase() + nameEn.slice(1);
        let formattedNameFr = nameFr.charAt(0).toUpperCase() + nameFr.slice(1);
        
        if (pokemon.form && pokemon.form !== pokemon.name) {
          let formPart = pokemon.form;
          if (formPart.startsWith(pokemon.name + '-')) {
            formPart = formPart.substring(pokemon.name.length + 1);
          }
          formPart = formPart.split('-').map(s => s.charAt(0).toUpperCase() + s.slice(1)).join(' ');
          let formStrFr = formPart;
          formStrFr = formStrFr.replace(/Male/g, "Mâle");
          formStrFr = formStrFr.replace(/Female/g, "Femelle");
          formStrFr = formStrFr.replace(/Family Of Four/g, "Famille de Quatre");
          formStrFr = formStrFr.replace(/Family Of Three/g, "Famille de Trois");
          formStrFr = formStrFr.replace(/Mega/g, "Méga");
          formStrFr = formStrFr.replace(/Blade/g, "Lame");
          formStrFr = formStrFr.replace(/Shield/g, "Parade");
          formStrFr = formStrFr.replace(/Midnight/g, "Nocturne");
          formStrFr = formStrFr.replace(/Dusk/g, "Crépusculaire");
          formStrFr = formStrFr.replace(/Midday/g, "Diurne");
          formStrFr = formStrFr.replace(/Fan/g, "Hélice");
          formStrFr = formStrFr.replace(/Frost/g, "Froid");
          formStrFr = formStrFr.replace(/Heat/g, "Chaleur");
          formStrFr = formStrFr.replace(/Mow/g, "Tonte");
          formStrFr = formStrFr.replace(/Wash/g, "Lavage");
          formStrFr = formStrFr.replace(/Rainy/g, "Eau");
          formStrFr = formStrFr.replace(/Snowy/g, "Neige");
          formStrFr = formStrFr.replace(/Sunny/g, "Soleil");
          formStrFr = formStrFr.replace(/Paldea Combat Breed/g, "Paldea Combat");
          formStrFr = formStrFr.replace(/Paldea Blaze Breed/g, "Paldea Flamboyant");
          formStrFr = formStrFr.replace(/Paldea Aqua Breed/g, "Paldea Aquatique");
          
          formattedNameEn += `\n(${formPart})`;
          formattedNameFr += `\n(${formStrFr})`;
        }

        const displayName = currentLang === 'fr' ? formattedNameFr : formattedNameEn;

        return `
          <div class="team-member-container">
            <div class="team-circle glass-panel" style="--accent-color: var(--type-${primaryType})">
              <button class="remove-btn" data-id="${pokemon.id}" data-form="${pokemon.form}" aria-label="Remove" data-i18n-title="remove" title="${t('remove')}">×</button>
              <a href="${import.meta.env.BASE_URL}pokemon/${pokemon.id}-${pokemon.form}" class="circle-link">
                <img src="${import.meta.env.BASE_URL}data/champions/pokemon/${pokemon.id}/${pokemon.form}-front_default.png" alt="${displayName}" loading="lazy" crossorigin="anonymous" />
              </a>
              <div class="name-badge" data-name-en="${formattedNameEn.replace(/"/g, '&quot;')}" data-name-fr="${formattedNameFr.replace(/"/g, '&quot;')}">${displayName}</div>
            </div>
            <button class="config-btn action-btn" data-id="${pokemon.id}" data-form="${pokemon.form}" data-name="${displayName}" data-i18n="repartition">${t('repartition')}</button>
          </div>
        `;
      }).join('');

      // Add listeners for config buttons
      document.querySelectorAll('.config-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const t = e.currentTarget as HTMLElement;
          openConfigModal(parseInt(t.dataset.id!), t.dataset.form!, t.dataset.name!);
        });
      });

      if (teamStatsGrid) {
        teamStatsGrid.innerHTML = team.map(pokemon => {
          const primaryType = pokemon.types[0] || 'normal';
          const currentLang = getLang();
          
          const names = globalPokemonNamesMap[`${pokemon.id}-${pokemon.form}`] || {};
          const nameEn = names.name_en || pokemon.name_en || pokemon.name;
          const nameFr = names.name_fr || pokemon.name_fr || nameEn;
          
          let formattedNameEn = nameEn.charAt(0).toUpperCase() + nameEn.slice(1);
          let formattedNameFr = nameFr.charAt(0).toUpperCase() + nameFr.slice(1);
          
          if (pokemon.form && pokemon.form !== pokemon.name) {
            let formPart = pokemon.form;
            if (formPart.startsWith(pokemon.name + '-')) {
              formPart = formPart.substring(pokemon.name.length + 1);
            }
            formPart = formPart.split('-').map(s => s.charAt(0).toUpperCase() + s.slice(1)).join(' ');
            formattedNameEn += `\n(${formPart})`;
            formattedNameFr += `\n(${formPart})`;
          }

          const displayName = currentLang === 'fr' ? formattedNameFr : formattedNameEn;

          const stats = window.pokemonStatsMap[`${pokemon.id}_${pokemon.form}`] || [];
          
          const natureId = pokemon.nature || '25';
          const natureData = globalNaturesMap[natureId];
          const incStat = natureData?.increased_stat;
          const decStat = natureData?.decreased_stat;
          
          let statsHtml = stats.map((s: any) => {
            let colorStyle = '';
            
            const additiveBonus = s.stat.name === 'hp' ? 75 : 20;
            const evBonus = (pokemon.evs && pokemon.evs[s.stat.name]) ? pokemon.evs[s.stat.name] : 0;
            let finalVal = s.base_stat + additiveBonus + evBonus;

            if (s.stat.name === incStat) {
               colorStyle = 'color: #ff8787;';
               finalVal = Math.floor(finalVal * 1.1);
            }
            else if (s.stat.name === decStat) {
               colorStyle = 'color: #74c0fc;';
               finalVal = Math.floor(finalVal * 0.9);
            }
            
            return `
            <div class="stat-row">
              <span class="stat-name" style="${colorStyle}" data-i18n="stat_${s.stat.name}">${t('stat_' + s.stat.name)}</span>
              <span class="stat-val" style="${colorStyle}">${finalVal}</span>
              <div class="stat-bar-bg">
                <div class="stat-bar-fill" style="width: ${Math.min((finalVal / 255) * 100, 100)}%; background-color: var(--accent-color);"></div>
              </div>
            </div>
          `}).join('');

          let natureStr = '';
          if (natureData) {
            const natureName = currentLang === 'fr' ? (natureData.name_fr || natureData.name_en) : natureData.name_en;
            if (natureData.id !== '25' && natureData.increased_stat && natureData.decreased_stat) {
               const incFmt = t('stat_' + natureData.increased_stat);
               const decFmt = t('stat_' + natureData.decreased_stat);
               natureStr = `<div class="config-badge nature-badge" style="background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.3);">${natureName} (<span style="color:#ff8787;">+ ${incFmt}</span> / <span style="color:#74c0fc;">- ${decFmt}</span>)</div>`;
            } else {
               natureStr = `<div class="config-badge nature-badge" style="background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.3);">${natureName}</div>`;
            }
          }
          
          let abilityName = pokemon.ability;
          let abilityDesc = '';
          if (pokemon.ability && globalAbilitiesMap[pokemon.ability]) {
            const abData = globalAbilitiesMap[pokemon.ability];
            abilityName = currentLang === 'fr' ? (abData.name_fr || abData.name_en) : abData.name_en;
            abilityDesc = currentLang === 'fr' ? (abData.description_fr || abData.description_en) : abData.description_en;
          } else if (pokemon.ability) {
            abilityName = pokemon.ability.charAt(0).toUpperCase() + pokemon.ability.slice(1);
          }
          const safeAbDesc = abilityDesc ? abilityDesc.replace(/"/g, '&quot;') : '';
          const abilityStr = abilityName ? `<div class="config-badge ability-badge has-tooltip" data-tooltip="${safeAbDesc}">${abilityName}</div>` : '';
          
          const movesHtml = pokemon.moves ? pokemon.moves.filter(m => m).map(m => {
            let mName = String(m);
            let mDesc = '';
            if (globalMovesNameMap[m]) {
              mName = currentLang === 'fr' ? globalMovesNameMap[m].fr : globalMovesNameMap[m].en;
              mDesc = currentLang === 'fr' ? globalMovesNameMap[m].desc_fr : globalMovesNameMap[m].desc_en;
            }
            const safeDesc = mDesc ? mDesc.replace(/"/g, '&quot;') : '';
            return `<div class="config-badge move-badge has-tooltip" data-tooltip="${safeDesc}">${mName.charAt(0).toUpperCase() + mName.slice(1)}</div>`;
          }).join('') : '';
          
          let evsHtml = '';
          if (pokemon.evs) {
            const evs = pokemon.evs;
            const evList = [];
            if (evs.hp > 0) evList.push(`${t('ev_hp')}: ${evs.hp}`);
            if (evs.attack > 0) evList.push(`${t('ev_attack')}: ${evs.attack}`);
            if (evs.defense > 0) evList.push(`${t('ev_defense')}: ${evs.defense}`);
            if (evs['special-attack'] > 0) evList.push(`${t('ev_special-attack')}: ${evs['special-attack']}`);
            if (evs['special-defense'] > 0) evList.push(`${t('ev_special-defense')}: ${evs['special-defense']}`);
            if (evs.speed > 0) evList.push(`${t('ev_speed')}: ${evs.speed}`);
            if (evList.length > 0) {
              evsHtml = `<div class="evs-summary">${evList.join(' | ')}</div>`;
            }
          }

          let itemHtml = '';
          if (pokemon.item && globalItemsMap[pokemon.item]) {
            const itmData = globalItemsMap[pokemon.item];
            const iName = currentLang === 'fr' ? (itmData.name_fr || itmData.name_en) : itmData.name_en;
            const iEffect = currentLang === 'fr' ? (itmData.effect_fr || itmData.effect_en) : itmData.effect_en;
            itemHtml = `<div class="config-badge item-badge has-tooltip" data-tooltip="${iEffect ? iEffect.replace(/"/g, '&quot;') : iName}" style="display:inline-flex; align-items:center; gap:0.25rem; background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.1);">
              <img src="${itmData.sprite}" alt="${iName}" style="width:20px; height:20px; image-rendering: pixelated; margin:-4px 0;" />
              <span>${iName}</span>
            </div>`;
          }

          return `
            <div class="team-stat-card glass-panel" style="--accent-color: var(--type-${primaryType}); position: relative;">
              <div class="stat-card-header">
                <div style="display:flex; align-items:center; gap: 0.5rem; justify-content:center;">
                  <img src="${import.meta.env.BASE_URL}data/champions/pokemon/${pokemon.id}/${pokemon.form}-front_default.png" alt="${displayName} icon" style="width: 48px; height: 48px; object-fit: contain; image-rendering: pixelated; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3)); margin-top: -10px; margin-bottom: -10px;" />
                  <h3 data-name-en="${formattedNameEn.replace(/"/g, '&quot;')}" data-name-fr="${formattedNameFr.replace(/"/g, '&quot;')}">${displayName}</h3>
                </div>
                <div class="types" style="display:flex; gap:0.5rem; justify-content:center; align-items:center; margin-top: 0.5rem;">
                  ${pokemon.types.map((t_str: string) => `<span class="type-badge bg-${t_str}" data-i18n="type_${t_str}">${t('type_' + t_str)}</span>`).join('')}
                </div>
              </div>
              ${abilityStr || movesHtml || natureStr || itemHtml ? `
              <div class="stat-card-config">
                ${natureStr}
                <div style="display:flex; gap:0.5rem; justify-content:center; flex-wrap:wrap; margin-bottom:0.25rem;">
                  ${abilityStr}
                  ${itemHtml}
                </div>
                <div class="moves-container">${movesHtml}</div>
                ${evsHtml}
              </div>` : ''}
              <div class="stat-card-body" style="margin-top:1rem;">
                ${statsHtml}
              </div>
            </div>
          `;
        }).join('');
      }

      document.querySelectorAll('.team-circle .remove-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const id = parseInt((e.target as HTMLElement).dataset.id!);
          const form = (e.target as HTMLElement).dataset.form!;
          removeFromTeam(id, form);
          renderUI();
        });
      });
    }

    function renderUI() {
      renderTeamList();
      renderTeamGrid();
    }

    if (createTeamBtn) {
      createTeamBtn.addEventListener('click', () => {
        createTeam();
        renderUI();
      });
    }

    if (toggleStatsBtn && teamStatsGrid) {
      toggleStatsBtn.addEventListener('click', () => {
        teamStatsGrid.classList.toggle('hidden-collapsible');
        if (teamStatsGrid.classList.contains('hidden-collapsible')) {
          toggleStatsBtn.innerHTML = t('show_stats') + ' ▼';
          teamStatsGrid.style.overflow = 'hidden';
        } else {
          toggleStatsBtn.innerHTML = t('show_stats').replace('Show', 'Hide').replace('Afficher', 'Masquer') + ' ▲';
          setTimeout(() => {
            if (!teamStatsGrid.classList.contains('hidden-collapsible')) {
              teamStatsGrid.style.overflow = 'visible';
            }
          }, 400);
        }
      });
    }

    if (btnExportMain && exportOptions) {
      btnExportMain.addEventListener('click', () => {
        exportOptions.classList.toggle('hidden');
      });
    }

    renderUI();
    window.addEventListener('team-data-updated', renderUI);

    // --- Global Tooltip Logic ---
    const globalTooltip = document.createElement('div');
    globalTooltip.className = 'global-tooltip hidden';
    document.body.appendChild(globalTooltip);

    document.addEventListener('mouseover', (e) => {
      const target = (e.target as HTMLElement).closest('.has-tooltip') as HTMLElement;
      if (target && target.dataset.tooltip) {
        globalTooltip.innerHTML = target.dataset.tooltip;
        globalTooltip.classList.remove('hidden');
      }
    });
    
    document.addEventListener('mousemove', (e) => {
      if (!globalTooltip.classList.contains('hidden')) {
        const tooltipRect = globalTooltip.getBoundingClientRect();
        let top = e.clientY + 15;
        let left = e.clientX + 15;
        if (left + tooltipRect.width > window.innerWidth) {
            left = e.clientX - tooltipRect.width - 15;
        }
        if (top + tooltipRect.height > window.innerHeight) {
            top = e.clientY - tooltipRect.height - 15;
        }
        globalTooltip.style.left = left + 'px';
        globalTooltip.style.top = top + 'px';
      }
    });

    document.addEventListener('mouseout', (e) => {
      const target = (e.target as HTMLElement).closest('.has-tooltip');
      if (target) {
        globalTooltip.classList.add('hidden');
      }
    });

    // --- Custom Select Dropdown Logic ---
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      
      // Close all ability dropdowns if clicking outside
      const abilityWrapper = document.getElementById('ability-select-wrapper');
      if (abilityWrapper && !abilityWrapper.contains(target)) {
        document.getElementById('ability-select-dropdown')?.classList.add('hidden');
      }
      
      // Close all item dropdowns if clicking outside
      const itemWrapper = document.getElementById('item-select-wrapper');
      if (itemWrapper && !itemWrapper.contains(target)) {
        document.getElementById('item-select-dropdown')?.classList.add('hidden');
      }
      
      // Close all move dropdowns if clicking outside
      for (let i = 1; i <= 4; i++) {
        const moveWrapper = document.getElementById(`move-select-wrapper-${i}`);
        if (moveWrapper && !moveWrapper.contains(target)) {
          document.getElementById(`move-select-dropdown-${i}`)?.classList.add('hidden');
        }
      }
      
      // Toggle ability dropdown
      if (target.closest('#ability-select-trigger')) {
         const dropdown = document.getElementById('ability-select-dropdown');
         dropdown?.classList.toggle('hidden');
      }
      
      // Toggle item dropdown
      if (target.closest('#item-select-trigger')) {
         const dropdown = document.getElementById('item-select-dropdown');
         dropdown?.classList.toggle('hidden');
         if (!dropdown?.classList.contains('hidden')) {
            document.getElementById('item-search-input')?.focus();
         }
      }
      
      // Toggle move dropdowns
      const moveTrigger = target.closest('.custom-select-trigger[id^="move-select-trigger-"]');
      if (moveTrigger) {
         const i = (moveTrigger as HTMLElement).dataset.index;
         const dropdown = document.getElementById(`move-select-dropdown-${i}`);
         dropdown?.classList.toggle('hidden');
         if (!dropdown?.classList.contains('hidden')) {
            document.getElementById(`move-search-input-${i}`)?.focus();
         }
      }
    });

    // --- Configuration Modal Logic ---
    const configModal = document.getElementById('config-modal');
    const closeConfigBtn = document.getElementById('close-config-btn');
    const saveConfigBtn = document.getElementById('save-config-btn');
    const evSliders = document.querySelectorAll('.ev-slider');
    const evTotalEl = document.getElementById('ev-total');
    
    let currentEvs = { hp: 0, attack: 0, defense: 0, 'special-attack': 0, 'special-defense': 0, speed: 0 };
    
    function updateModalFinalStats() {
      const pId = (document.getElementById('config-pokemon-id') as HTMLInputElement).value;
      const pForm = (document.getElementById('config-pokemon-form') as HTMLInputElement).value;
      if (!pId || !pForm) return;
      const stats = window.pokemonStatsMap[`${pId}_${pForm}`] || [];
      const natureHidden = (document.getElementById('config-nature-hidden') as HTMLInputElement).value;
      const natData = globalNaturesMap[natureHidden];
      const incStat = natData?.increased_stat;
      const decStat = natData?.decreased_stat;

      ['hp', 'attack', 'defense', 'special-attack', 'special-defense', 'speed'].forEach(statName => {
        const baseStatObj = stats.find((s: any) => s.stat.name === statName);
        if (!baseStatObj) return;
        let baseVal = baseStatObj.base_stat;
        if (statName === 'hp') baseVal += 75;
        else baseVal += 20;

        const evVal = currentEvs[statName as keyof typeof currentEvs] || 0;
        let total = baseVal + evVal;
        
        let statColor = '#ffd43b';
        if (statName === incStat) {
           total = Math.floor(total * 1.1);
           statColor = '#ff8787';
        } else if (statName === decStat) {
           total = Math.floor(total * 0.9);
           statColor = '#74c0fc';
        }
        
        const finalSpan = document.getElementById(`ev-final-${statName}`);
        if (finalSpan) {
           finalSpan.textContent = ` ➞ ${total}`;
           finalSpan.style.color = statColor;
           finalSpan.style.fontWeight = 'bold';
           finalSpan.style.marginLeft = '4px';
        }
      });
    }
    
    evSliders.forEach(slider => {
      const s = slider as HTMLInputElement;
      const statName = s.id === 'ev-hp' ? 'hp' : s.dataset.stat!;
      s.addEventListener('input', (e) => {
        const newVal = parseInt((e.target as HTMLInputElement).value) || 0;
        const oldVal = currentEvs[statName as keyof typeof currentEvs];
        let diff = newVal - oldVal;
        
        let totalEvs = Object.values(currentEvs).reduce((a, b) => a + b, 0);
        
        if (totalEvs + diff > 66) {
          const allowedDiff = 66 - totalEvs;
          const cappedVal = oldVal + allowedDiff;
          s.value = cappedVal.toString();
          currentEvs[statName as keyof typeof currentEvs] = cappedVal;
        } else {
          currentEvs[statName as keyof typeof currentEvs] = newVal;
        }
        
        document.getElementById(`ev-val-${statName}`)!.textContent = currentEvs[statName as keyof typeof currentEvs].toString();
        
        totalEvs = Object.values(currentEvs).reduce((a, b) => a + b, 0);
        evTotalEl!.textContent = totalEvs.toString();
        updateModalFinalStats();
      });
    });

    if (closeConfigBtn) {
      closeConfigBtn.addEventListener('click', () => {
        configModal!.classList.add('hidden');
      });
    }

    if (saveConfigBtn) {
      saveConfigBtn.addEventListener('click', () => {
        const pId = parseInt((document.getElementById('config-pokemon-id') as HTMLInputElement).value);
        const pForm = (document.getElementById('config-pokemon-form') as HTMLInputElement).value;
        const teamId = getActiveTeamId();
        
        const ability = (document.getElementById('config-ability-hidden') as HTMLInputElement).value;
        const nature = (document.getElementById('config-nature-hidden') as HTMLInputElement).value;
        const item = (document.getElementById('config-item-hidden') as HTMLInputElement).value;
        const moves = [
          (document.getElementById('config-move-1-hidden') as HTMLInputElement).value,
          (document.getElementById('config-move-2-hidden') as HTMLInputElement).value,
          (document.getElementById('config-move-3-hidden') as HTMLInputElement).value,
          (document.getElementById('config-move-4-hidden') as HTMLInputElement).value
        ].filter(m => m !== '');

        updatePokemonConfig(pId, pForm, {
          ability: ability || null,
          nature: nature || '25',
          item: item || null,
          moves: moves,
          evs: { ...currentEvs }
        });
        
        saveConfigBtn.textContent = 'Saved!';
        saveConfigBtn.style.backgroundColor = '#4ade80';
        setTimeout(() => {
          configModal!.classList.add('hidden');
          saveConfigBtn.textContent = 'Save Configuration';
          saveConfigBtn.style.backgroundColor = '';
          renderUI();
        }, 1000);
      });
    }

    async function openConfigModal(id: number, form: string, displayName: string) {
      document.getElementById('config-modal-title')!.textContent = `${t('configure')} ${displayName}`;
      (document.getElementById('config-pokemon-id') as HTMLInputElement).value = id.toString();
      (document.getElementById('config-pokemon-form') as HTMLInputElement).value = form;
      
      const currentLang = getLang();
      // document.getElementById('config-item') is removed since we use custom select
      for (let i = 1; i <= 4; i++) {
        document.getElementById(`move-select-display-${i}`)!.innerHTML = `<span data-i18n="select_move_${i}">${t('select_move_' + i)}</span>`;
        (document.getElementById(`config-move-${i}-hidden`) as HTMLInputElement).value = '';
      }
      
      configModal!.classList.remove('hidden');

      try {
        const res = await fetch(`${import.meta.env.BASE_URL}data/champions/pokemon/${id}/${form}.json`);
        if (!res.ok) throw new Error("Could not fetch data");
        const data = await res.json();
        
        const abilityOptionsList = document.getElementById('ability-options-list')!;
        if (data.abilities && data.abilities.length > 0) {
          let abilityHtml = data.abilities.map((ab: any) => {
            const abData = globalAbilitiesMap[ab.ability.name];
            let abName = ab.ability.name;
            let desc = '';
            if (abData) {
               abName = currentLang === 'fr' ? (abData.name_fr || abData.name_en) : abData.name_en;
               desc = currentLang === 'fr' ? (abData.description_fr || abData.description_en) : abData.description_en;
            }
            const safeDesc = desc ? desc.replace(/"/g, '&quot;') : '';
            const hiddenText = currentLang === 'fr' ? ' (Caché)' : ' (Hidden)';
            const normalText = '';
            const displayName = abName.charAt(0).toUpperCase() + abName.slice(1) + (ab.is_hidden ? hiddenText : normalText);
            return `<div class="custom-option has-tooltip" data-value="${ab.ability.name}" data-name="${displayName.replace(/"/g, '&quot;')}" data-tooltip="${safeDesc}">
                      <span>${displayName}</span>
                    </div>`;
          }).join('');
          abilityOptionsList.innerHTML = abilityHtml;
          
          const abilityNodes = abilityOptionsList.querySelectorAll('.custom-option');
          abilityNodes.forEach(opt => {
            opt.addEventListener('click', (e) => {
              const target = e.currentTarget as HTMLElement;
              document.getElementById('config-ability-hidden')!.value = target.dataset.value || '';
              document.getElementById('ability-select-display')!.innerHTML = `<span>${target.dataset.name}</span>`;
              document.getElementById('ability-select-dropdown')!.classList.add('hidden');
              
              if (target.dataset.tooltip) {
                 document.getElementById('ability-select-trigger')?.setAttribute('data-tooltip', target.dataset.tooltip);
                 document.getElementById('ability-select-trigger')?.classList.add('has-tooltip');
              } else {
                 document.getElementById('ability-select-trigger')?.removeAttribute('data-tooltip');
                 document.getElementById('ability-select-trigger')?.classList.remove('has-tooltip');
              }
            });
          });
        }
        const pageContainer = document.getElementById('team-page-container');
        const movesNameMap = JSON.parse(decodeURIComponent(pageContainer?.dataset.moves || '{}'));

        const activeTeam = getActiveTeam();
        const pokemon = activeTeam.members.find((p: any) => p.id === id && p.form === form);
        
        const uniqueMoveIds = [...new Set(data.moves)];
        
        // Group by type
        const movesByType: { [key: string]: any[] } = {};
        
        uniqueMoveIds.forEach(mId => {
           let mName = String(mId);
           let mType = 'normal';
           let mDesc = '';
           if (movesNameMap[mId]) {
              mName = currentLang === 'fr' ? movesNameMap[mId].fr : movesNameMap[mId].en;
              mType = movesNameMap[mId].type || 'normal';
              mDesc = currentLang === 'fr' ? movesNameMap[mId].desc_fr : movesNameMap[mId].desc_en;
           }
           if (!movesByType[mType]) movesByType[mType] = [];
           movesByType[mType].push({ id: mId, name: mName, type: mType, desc: mDesc });
        });
        
        // Sort types alphabetically, then moves alphabetically within types
        const sortedTypes = Object.keys(movesByType).sort();
        sortedTypes.forEach(t => {
           movesByType[t].sort((a, b) => a.name.localeCompare(b.name));
        });

        // Generate HTML options
        let movesHtml = '';
        sortedTypes.forEach(type => {
           const typeStr = t('type_' + type) || type.toUpperCase();
           movesHtml += `<div class="custom-optgroup bg-${type}" style="background-color: var(--type-${type}, rgba(0,0,0,0.3)); color: white; display: flex; align-items: center; gap: 6px;"><span class="type-icon-dot" style="background-color: white; width: 8px; height: 8px; border-radius: 50%;"></span>${typeStr}</div>`;
           movesByType[type].forEach(m => {
              const safeDesc = m.desc ? m.desc.replace(/"/g, '&quot;') : '';
              movesHtml += `
                <div class="custom-option move-option has-tooltip" data-value="${m.id}" data-name="${m.name.replace(/"/g, '&quot;')}" data-type="${m.type}" data-tooltip="${safeDesc}">
                   <span class="move-type-indicator bg-${m.type}" style="width: 12px; height: 12px; border-radius: 50%; display: inline-block; background-color: var(--type-${m.type}); margin-right: 8px; border: 1px solid rgba(255,255,255,0.3);"></span>
                   <span>${m.name.charAt(0).toUpperCase() + m.name.slice(1)}</span>
                </div>
              `;
           });
        });

        for (let i = 1; i <= 4; i++) {
          const list = document.getElementById(`move-options-list-${i}`)!;
          list.innerHTML = `<div class="custom-option move-option" data-value="" data-name="${t('select_move_' + i)}"><span style="margin-left:20px;">-- ${t('select_move_' + i)} --</span></div>` + movesHtml;
          
          const search = document.getElementById(`move-search-input-${i}`) as HTMLInputElement;
          search.value = '';
          
          // Initial selection
          const currentMove = pokemon?.moves?.[i-1];
          if (currentMove) {
             (document.getElementById(`config-move-${i}-hidden`) as HTMLInputElement).value = String(currentMove);
             let mName = String(currentMove);
             let mType = 'normal';
             if (movesNameMap[currentMove]) {
                mName = currentLang === 'fr' ? movesNameMap[currentMove].fr : movesNameMap[currentMove].en;
                mType = movesNameMap[currentMove].type || 'normal';
             }
             document.getElementById(`move-select-display-${i}`)!.innerHTML = `<span class="move-type-indicator bg-${mType}" style="width: 12px; height: 12px; border-radius: 50%; display: inline-block; background-color: var(--type-${mType}); margin-right: 8px; border: 1px solid rgba(255,255,255,0.3);"></span><span>${mName.charAt(0).toUpperCase() + mName.slice(1)}</span>`;
          }

          // Attach listeners for options
          const optionsNodes = list.querySelectorAll('.move-option');
          optionsNodes.forEach(opt => {
            opt.addEventListener('click', (e) => {
               const target = e.currentTarget as HTMLElement;
               (document.getElementById(`config-move-${i}-hidden`) as HTMLInputElement).value = target.dataset.value || '';
               document.getElementById(`move-select-display-${i}`)!.innerHTML = target.innerHTML;
               document.getElementById(`move-select-dropdown-${i}`)!.classList.add('hidden');
            });
          });

          // Search filtering
          search.addEventListener('input', (e) => {
            const val = (e.target as HTMLInputElement).value.toLowerCase();
            optionsNodes.forEach(opt => {
              const name = (opt as HTMLElement).dataset.name || '';
              if (name.toLowerCase().includes(val)) {
                (opt as HTMLElement).style.display = 'flex';
              } else {
                (opt as HTMLElement).style.display = 'none';
              }
            });
            // Hide empty optgroups
            const groups = list.querySelectorAll('.custom-optgroup');
            groups.forEach(group => {
              let next = group.nextElementSibling;
              let hasVisible = false;
              while (next && next.classList.contains('move-option')) {
                if ((next as HTMLElement).style.display !== 'none') {
                  hasVisible = true;
                  break;
                }
                next = next.nextElementSibling;
              }
              (group as HTMLElement).style.display = hasVisible ? 'flex' : 'none';
            });
          });
        }
        
        const natureOptionsList = document.getElementById('nature-options-list')!;
        const natureSelectDisplay = document.getElementById('nature-select-display')!;
        const natureHiddenInput = document.getElementById('config-nature-hidden') as HTMLInputElement;
        
        natureOptionsList.innerHTML = '';
        
        const sortedNatures = Object.values(globalNaturesMap).sort((a: any, b: any) => {
          const nameA = currentLang === 'fr' ? (a.name_fr || a.name_en) : a.name_en;
          const nameB = currentLang === 'fr' ? (b.name_fr || b.name_en) : b.name_en;
          return nameA.localeCompare(nameB);
        });

        sortedNatures.forEach((nat: any) => {
          const opt = document.createElement('div');
          opt.className = 'custom-option';
          opt.dataset.value = String(nat.id);
          
          const natureName = currentLang === 'fr' ? (nat.name_fr || nat.name_en) : nat.name_en;
          const incStat = nat.increased_stat ? t('stat_' + nat.increased_stat) : (currentLang === 'fr' ? 'Aucune' : 'None');
          const decStat = nat.decreased_stat ? t('stat_' + nat.decreased_stat) : (currentLang === 'fr' ? 'Aucune' : 'None');
          
          let tooltipText = "";
          if (nat.increased_stat && nat.decreased_stat) {
             tooltipText = currentLang === 'fr' 
               ? `Augmente ${incStat} de 10%, diminue ${decStat} de 10%` 
               : `Increases ${incStat} by 10%, decreases ${decStat} by 10%`;
          } else {
             tooltipText = currentLang === 'fr' 
               ? `Nature neutre (Aucun changement de stat)` 
               : `Neutral nature (No stat changes)`;
          }
          opt.dataset.tooltip = tooltipText;

          if (nat.increased_stat && nat.decreased_stat) {
            opt.innerHTML = `
              <div class="custom-option-name">
                ${natureName} 
                <span style="color: #ff8787; font-size: 0.85em; margin-left: 0.3rem;">(+ ${incStat})</span> 
                <span style="color: #74c0fc; font-size: 0.85em; margin-left: 0.3rem;">(- ${decStat})</span>
              </div>
            `;
          } else {
            opt.innerHTML = `<div class="custom-option-name">${natureName}</div>`;
          }
          
          opt.addEventListener('click', () => {
            natureHiddenInput.value = opt.dataset.value!;
            natureSelectDisplay.innerHTML = `<span>${opt.innerHTML}</span>`;
            document.getElementById('nature-select-dropdown')?.classList.add('hidden');
            
            const trigger = document.getElementById('nature-select-trigger');
            if (opt.dataset.tooltip) {
               trigger?.setAttribute('data-tooltip', opt.dataset.tooltip);
               trigger?.classList.add('has-tooltip');
            } else {
               trigger?.removeAttribute('data-tooltip');
               trigger?.classList.remove('has-tooltip');
            }
            
            // Color EV labels
            const inc = nat.increased_stat;
            const dec = nat.decreased_stat;
            const statNames = ['hp', 'attack', 'defense', 'special-attack', 'special-defense', 'speed'];
            statNames.forEach(stat => {
              const labelEl = document.querySelector(`div.ev-row:has(#ev-slider-${stat}) label, div.ev-row:has(#ev-${stat}) label`);
              if (labelEl) {
                 if (stat === inc) {
                   (labelEl as HTMLElement).style.color = '#ff8787'; // Reddish
                 } else if (stat === dec) {
                   (labelEl as HTMLElement).style.color = '#74c0fc'; // Blueish
                 } else {
                   (labelEl as HTMLElement).style.color = 'var(--text-color)';
                 }
              }
            });

            updateModalFinalStats();
          });
          
          natureOptionsList.appendChild(opt);
        });

        // Initialize nature custom select trigger
        document.getElementById('nature-select-trigger')?.addEventListener('click', (e) => {
          e.stopPropagation();
          const dropdown = document.getElementById('nature-select-dropdown');
          const isHidden = dropdown?.classList.contains('hidden');
          
          document.querySelectorAll('.custom-select-dropdown').forEach(el => el.classList.add('hidden'));
          
          if (isHidden) {
             dropdown?.classList.remove('hidden');
          }
        });

        // --- Populate custom item select ---
        const itemOptionsList = document.getElementById('item-options-list')!;
        const itemSearchInput = document.getElementById('item-search-input') as HTMLInputElement;
        const itemSelectDisplay = document.getElementById('item-select-display')!;
        const itemHiddenInput = document.getElementById('config-item-hidden') as HTMLInputElement;
        
        itemOptionsList.innerHTML = '';
        itemSearchInput.value = '';
        
        // Categorize items
        const categories = {
          megas: { title: currentLang === 'fr' ? 'Méga-Gemmes' : 'Mega Stones', items: [] as any[] },
          berries: { title: currentLang === 'fr' ? 'Baies' : 'Berries', items: [] as any[] },
          held: { title: currentLang === 'fr' ? 'Objets Tenus' : 'Held Items', items: [] as any[] }
        };

        validItems.forEach((itm: any) => {
          const nameEn = (itm.name_en || '').toLowerCase();
          itm.displayName = currentLang === 'fr' ? (itm.name_fr || itm.name_en) : itm.name_en;
          itm.displayEffect = currentLang === 'fr' ? (itm.effect_fr || itm.effect_en || '') : (itm.effect_en || '');
          
          if (nameEn.includes('berry')) {
            categories.berries.items.push(itm);
          } else if ((nameEn.includes('ite') || nameEn.endsWith('ite') || nameEn.includes('ite x') || nameEn.includes('ite y')) && !nameEn.includes('eviolite') && !nameEn.includes('white') && !nameEn.includes('meteorite')) {
            categories.megas.items.push(itm);
          } else {
            categories.held.items.push(itm);
          }
        });

        // Sort items in each category
        Object.values(categories).forEach(cat => {
          cat.items.sort((a, b) => a.displayName.localeCompare(b.displayName));
        });

        // Generate HTML for options
        let itemHtml = `<div class="custom-option" data-value="" data-name="${t('no_item')}">
                          <span style="margin-left: 28px;">${t('no_item')}</span>
                        </div>`;

        Object.values(categories).forEach(cat => {
          if (cat.items.length === 0) return;
          itemHtml += `<div class="custom-optgroup">${cat.title}</div>`;
          cat.items.forEach(itm => {
             const effectSafe = itm.displayEffect ? itm.displayEffect.replace(/"/g, '&quot;') : '';
             itemHtml += `
               <div class="custom-option has-tooltip" data-value="${itm.id}" data-name="${itm.displayName.replace(/"/g, '&quot;')}" data-tooltip="${effectSafe}">
                 <img src="${itm.sprite || ''}" class="custom-option-icon" alt="" onerror="this.style.display='none'" />
                 <span>${itm.displayName}</span>
               </div>
             `;
          });
        });
        itemOptionsList.innerHTML = itemHtml;

        // Set initial selected item
        const selectedItem = pokemon?.item;
        itemHiddenInput.value = selectedItem || '';
        if (selectedItem && globalItemsMap[selectedItem]) {
          const itmData = globalItemsMap[selectedItem];
          const iName = currentLang === 'fr' ? (itmData.name_fr || itmData.name_en) : itmData.name_en;
          itemSelectDisplay.innerHTML = `<img src="${itmData.sprite}" class="custom-option-icon" style="margin-right:8px;" alt=""/><span>${iName}</span>`;
          
          const iEffect = currentLang === 'fr' ? (itmData.effect_fr || itmData.effect_en) : itmData.effect_en;
          if (iEffect) document.getElementById('item-select-trigger')?.setAttribute('data-tooltip', iEffect);
          else document.getElementById('item-select-trigger')?.removeAttribute('data-tooltip');
        } else {
          itemSelectDisplay.innerHTML = `<span>${t('no_item')}</span>`;
          document.getElementById('item-select-trigger')?.removeAttribute('data-tooltip');
        }

        // Attach event listeners for custom select options
        const optionsNodes = itemOptionsList.querySelectorAll('.custom-option');
        optionsNodes.forEach(opt => {
          opt.addEventListener('click', (e) => {
            const target = e.currentTarget as HTMLElement;
            itemHiddenInput.value = target.dataset.value || '';
            itemSelectDisplay.innerHTML = target.innerHTML;
            document.getElementById('item-select-dropdown')!.classList.add('hidden');
            
            if (target.dataset.tooltip) {
               document.getElementById('item-select-trigger')?.setAttribute('data-tooltip', target.dataset.tooltip);
            } else {
               document.getElementById('item-select-trigger')?.removeAttribute('data-tooltip');
            }
          });
        });

        // Search filtering
        itemSearchInput.addEventListener('input', (e) => {
          const val = (e.target as HTMLInputElement).value.toLowerCase();
          optionsNodes.forEach(opt => {
            const name = (opt as HTMLElement).dataset.name || '';
            if (name.toLowerCase().includes(val)) {
              (opt as HTMLElement).style.display = 'flex';
            } else {
              (opt as HTMLElement).style.display = 'none';
            }
          });
          // Hide empty optgroups
          const groups = itemOptionsList.querySelectorAll('.custom-optgroup');
          groups.forEach(group => {
            let next = group.nextElementSibling;
            let hasVisible = false;
            while (next && next.classList.contains('custom-option')) {
              if ((next as HTMLElement).style.display !== 'none') {
                hasVisible = true;
                break;
              }
              next = next.nextElementSibling;
            }
            (group as HTMLElement).style.display = hasVisible ? 'block' : 'none';
          });
        });
        


        const updateMoveSelects = () => {
          const selectedMoves: string[] = [];
          for (let i = 1; i <= 4; i++) {
            const val = (document.getElementById(`config-move-${i}`) as HTMLSelectElement).value;
            if (val) selectedMoves.push(val);
          }
          for (let i = 1; i <= 4; i++) {
            const select = document.getElementById(`config-move-${i}`) as HTMLSelectElement;
            Array.from(select.options).forEach(opt => {
              if (opt.value !== "" && opt.value !== select.value && selectedMoves.includes(opt.value)) {
                opt.disabled = true;
              } else {
                opt.disabled = false;
              }
            });
          }
        };

        for (let i = 1; i <= 4; i++) {
          const moveSelect = document.getElementById(`config-move-${i}`) as HTMLSelectElement;
          if (moveSelect) {
            moveSelect.onchange = updateMoveSelects;
          }
        }

        if (pokemon) {
          const natureHiddenInput = document.getElementById('config-nature-hidden') as HTMLInputElement;
          const targetNat = pokemon.nature ? pokemon.nature : '25';
          natureHiddenInput.value = targetNat;
          const optToClick = document.querySelector(`#nature-options-list .custom-option[data-value="${targetNat}"]`) as HTMLElement;
          if (optToClick) optToClick.click();
          
          if (pokemon.item) itemSelect.value = pokemon.item;
          updateItemTooltip();
          
          if (pokemon.ability) {
             const abHiddenInput = document.getElementById('config-ability-hidden') as HTMLInputElement;
             abHiddenInput.value = pokemon.ability;
             const abOpt = document.querySelector(`#ability-options-list .custom-option[data-value="${pokemon.ability}"]`) as HTMLElement;
             if (abOpt) {
                document.getElementById('ability-select-display')!.innerHTML = `<span>${abOpt.dataset.name}</span>`;
                if (abOpt.dataset.tooltip) {
                    document.getElementById('ability-select-trigger')?.setAttribute('data-tooltip', abOpt.dataset.tooltip);
                    document.getElementById('ability-select-trigger')?.classList.add('has-tooltip');
                } else {
                    document.getElementById('ability-select-trigger')?.removeAttribute('data-tooltip');
                    document.getElementById('ability-select-trigger')?.classList.remove('has-tooltip');
                }
             }
          } else {
             // Fallback to first ability if none is set
             const firstAbOpt = document.querySelector('#ability-options-list .custom-option') as HTMLElement;
             if (firstAbOpt) {
                (document.getElementById('config-ability-hidden') as HTMLInputElement).value = firstAbOpt.dataset.value || '';
                document.getElementById('ability-select-display')!.innerHTML = `<span>${firstAbOpt.dataset.name}</span>`;
                if (firstAbOpt.dataset.tooltip) {
                    document.getElementById('ability-select-trigger')?.setAttribute('data-tooltip', firstAbOpt.dataset.tooltip);
                    document.getElementById('ability-select-trigger')?.classList.add('has-tooltip');
                }
             }
          }
          if (pokemon.moves) {
            pokemon.moves.forEach((m: string, idx: number) => {
              if (m && idx < 4) (document.getElementById(`config-move-${idx+1}`) as HTMLInputElement).value = m;
            });
          }
          updateMoveSelects();
          if (pokemon.evs) {
            currentEvs = { ...pokemon.evs };
            Object.entries(currentEvs).forEach(([stat, val]) => {
              const slider = stat === 'hp' ? document.getElementById('ev-hp') : document.getElementById(`ev-slider-${stat}`);
              if (slider) (slider as HTMLInputElement).value = (val as number).toString();
              const valLabel = document.getElementById(`ev-val-${stat}`);
              if (valLabel) valLabel.textContent = (val as number).toString();
            });
            const total = Object.values(currentEvs).reduce((a, b) => a + (b as number), 0);
            evTotalEl!.textContent = total.toString();
          }
          updateModalFinalStats();
        }
      } catch (err) {
        console.error("Error loading config data:", err);
      }
    }

    const typeButtons = document.querySelectorAll('.type-btn');
    const pokedexCards = document.querySelectorAll('.team-pokedex-section .pokemon-card');
    let activeTypes = new Set(['all']);

    const btnAll = Array.from(typeButtons).find(b => (b as HTMLElement).dataset.type === 'all');

    typeButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const type = (btn as HTMLElement).dataset.type!;
        
        if (type === 'all') {
          activeTypes.clear();
          activeTypes.add('all');
          typeButtons.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
        } else {
          activeTypes.delete('all');
          btnAll?.classList.remove('active');

          if (activeTypes.has(type)) {
            activeTypes.delete(type);
            btn.classList.remove('active');
          } else {
            activeTypes.add(type);
            btn.classList.add('active');
          }

          if (activeTypes.size === 0) {
            activeTypes.add('all');
            btnAll?.classList.add('active');
          }
        }

        filterPokedex();
      });
    });

    function filterPokedex() {
      pokedexCards.forEach(card => {
        const btn = card.querySelector('.quick-add-btn') as HTMLElement;
        if (!btn) return;
        const types = btn.dataset.types!.split(',');

        const form = card.querySelector(".pokemon-name")?.textContent?.toLowerCase() || "";
        const isMega = form.includes("mega") || form.includes("méga");

        let matchType = activeTypes.has('all') || (activeTypes.has('mega') ? isMega : types.some(t => activeTypes.has(t)));

        if (matchType) {
          (card as HTMLElement).style.display = '';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    }

    // Export Logic
    async function captureTeam() {
      const activeTeam = getActiveTeam();
      if (exportTeamName) exportTeamName.textContent = activeTeam.name;

      if (exportHeader) exportHeader.classList.remove('hidden');
      document.querySelectorAll('.team-circle .remove-btn').forEach(b => (b as HTMLElement).style.display = 'none');
      if (captureArea) {
        captureArea.style.padding = '2rem';
        captureArea.style.background = '#121416';
        captureArea.style.borderRadius = '16px';
      }

      try {
        const canvas = await html2canvas(captureArea, {
          backgroundColor: '#121416',
          useCORS: true,
          scale: 2
        });
        return canvas;
      } finally {
        if (exportHeader) exportHeader.classList.add('hidden');
        document.querySelectorAll('.team-circle .remove-btn').forEach(b => (b as HTMLElement).style.display = '');
        if (captureArea) {
          captureArea.style.padding = '';
          captureArea.style.background = '';
          captureArea.style.borderRadius = '';
        }
      }
    }

    if (btnPng) {
      btnPng.addEventListener('click', async () => {
        const ogText = btnPng.innerHTML;
        btnPng.innerHTML = '<span>⏳</span> Exporting...';
        btnPng.classList.add('loading');
        
        try {
          const canvas = await captureTeam();
          const link = document.createElement('a');
          link.download = `team-${getActiveTeam().name.toLowerCase().replace(/\s+/g, '-')}.png`;
          link.href = canvas.toDataURL('image/png');
          link.click();
        } catch (e) {
          console.error("Export PNG Error:", e);
          alert("Error during PNG export.");
        } finally {
          btnPng.innerHTML = ogText;
          btnPng.classList.remove('loading');
        }
      });
    }

    if (btnPdf) {
      btnPdf.addEventListener('click', async () => {
        const ogText = btnPdf.innerHTML;
        btnPdf.innerHTML = '<span>⏳</span> Exporting...';
        btnPdf.classList.add('loading');
        
        try {
          const canvas = await captureTeam();
          const imgData = canvas.toDataURL('image/png');
          
          const pdf = new jsPDF({
            orientation: 'landscape',
            unit: 'mm',
            format: 'a4'
          });

          const pdfWidth = pdf.internal.pageSize.getWidth();
          const pdfHeight = pdf.internal.pageSize.getHeight();

          const imgWidth = canvas.width;
          const imgHeight = canvas.height;
          const ratio = Math.min(pdfWidth / imgWidth, pdfHeight / imgHeight);
          
          const finalWidth = imgWidth * ratio;
          const finalHeight = imgHeight * ratio;
          
          const marginX = (pdfWidth - finalWidth) / 2;
          const marginY = (pdfHeight - finalHeight) / 2;

          pdf.addImage(imgData, 'PNG', marginX, marginY, finalWidth, finalHeight);
          pdf.save(`team-${getActiveTeam().name.toLowerCase().replace(/\s+/g, '-')}.pdf`);
        } catch (e) {
          console.error("Export PDF Error:", e);
          alert("Error during PDF export.");
        } finally {
          btnPdf.innerHTML = ogText;
          btnPdf.classList.remove('loading');
        }
      });
    }
  </script>
</Layout>

<style is:global>
