---
import Layout from "../layouts/Layout.astro";
import PokemonCard from "../components/PokemonCard.astro";

// Fetch all local JSON files
const pokemonFiles = import.meta.glob(
	"../../../data/champions/pokemon/**/*.json",
	{ eager: true },
);

// Extract the default export (which is the JSON content)
const allPokemons = Object.values(pokemonFiles).map(
	(file: any) => file.default,
);

// Filter out G-Max and unwanted Pikachu forms
const validPokemons = allPokemons.filter((p) => {
	if (p.form.includes("-gmax")) return false;
	if (p.id === 25 && p.form !== "pikachu") return false; // Pikachu forms exclusion
	return true;
});

let pokemons = validPokemons;

// Sort by ID, then by Form to ensure base form is before alternate forms
pokemons.sort((a, b) => {
	if (a.id !== b.id) return a.id - b.id;
	if (a.form === a.name) return -1;
	if (b.form === b.name) return 1;
	return a.form.localeCompare(b.form);
});
---

<Layout title="Pokédex | PokeCraft">
	<header class="page-header">
		<h1 data-i18n="pokedex">Pokédex</h1>
		<p>
			<span data-i18n="explore_all">Explore all the</span> {pokemons.length} <span data-i18n="pokemon_on">Pokémon on Pokemon Champions!</span>
		</p>
	</header>

	<div class="pokedex-filters">
		<div class="type-filter-buttons" id="pokedex-type-filter">
			<button class="type-btn active" data-type="all" data-i18n="type_all">All</button>
			<button class="type-btn bg-normal" data-type="normal" data-i18n="type_normal">Normal</button>
			<button class="type-btn bg-fire" data-type="fire" data-i18n="type_fire">Fire</button>
			<button class="type-btn bg-water" data-type="water" data-i18n="type_water">Water</button>
			<button class="type-btn bg-grass" data-type="grass" data-i18n="type_grass">Grass</button>
			<button class="type-btn bg-electric" data-type="electric" data-i18n="type_electric">Electric</button>
			<button class="type-btn bg-ice" data-type="ice" data-i18n="type_ice">Ice</button>
			<button class="type-btn bg-fighting" data-type="fighting" data-i18n="type_fighting">Fighting</button>
			<button class="type-btn bg-poison" data-type="poison" data-i18n="type_poison">Poison</button>
			<button class="type-btn bg-ground" data-type="ground" data-i18n="type_ground">Ground</button>
			<button class="type-btn bg-flying" data-type="flying" data-i18n="type_flying">Flying</button>
			<button class="type-btn bg-psychic" data-type="psychic" data-i18n="type_psychic">Psychic</button>
			<button class="type-btn bg-bug" data-type="bug" data-i18n="type_bug">Bug</button>
			<button class="type-btn bg-rock" data-type="rock" data-i18n="type_rock">Rock</button>
			<button class="type-btn bg-ghost" data-type="ghost" data-i18n="type_ghost">Ghost</button>
			<button class="type-btn bg-dragon" data-type="dragon" data-i18n="type_dragon">Dragon</button>
			<button class="type-btn bg-dark" data-type="dark" data-i18n="type_dark">Dark</button>
			<button class="type-btn bg-steel" data-type="steel" data-i18n="type_steel">Steel</button>
			<button class="type-btn bg-fairy" data-type="fairy" data-i18n="type_fairy">Fairy</button>
		</div>
	</div>

	<main class="pokemon-grid" id="main-pokedex-grid">
		{pokemons.map((pokemon) => <PokemonCard pokemon={pokemon} />)}
	</main>
</Layout>

<script>
	const typeButtons = document.querySelectorAll(".type-btn");
	const pokedexCards = document.querySelectorAll(
		"#main-pokedex-grid .pokemon-card",
	);
	let activeTypes = new Set(["all"]);

	const btnAll = Array.from(typeButtons).find(
		(b) => (b as HTMLElement).dataset.type === "all",
	);

	typeButtons.forEach((btn) => {
		btn.addEventListener("click", () => {
			const type = (btn as HTMLElement).dataset.type!;

			if (type === "all") {
				activeTypes.clear();
				activeTypes.add("all");
				typeButtons.forEach((b) => b.classList.remove("active"));
				btn.classList.add("active");
			} else {
				activeTypes.delete("all");
				btnAll?.classList.remove("active");

				if (activeTypes.has(type)) {
					activeTypes.delete(type);
					btn.classList.remove("active");
				} else {
					activeTypes.add(type);
					btn.classList.add("active");
				}

				if (activeTypes.size === 0) {
					activeTypes.add("all");
					btnAll?.classList.add("active");
				}
			}

			filterPokedex();
		});
	});

	function filterPokedex() {
		pokedexCards.forEach((card) => {
			const btn = card.querySelector(".quick-add-btn") as HTMLElement;
			if (!btn) return;
			const types = btn.dataset.types!.split(",");

			let matchType =
				activeTypes.has("all") || types.some((t) => activeTypes.has(t));

			if (matchType) {
				(card as HTMLElement).style.display = "";
			} else {
				(card as HTMLElement).style.display = "none";
			}
		});
	}
</script>

<style>
	.page-header {
		text-align: center;
		margin-bottom: 3rem;
		padding-top: 2rem;
	}

	.page-header p {
		color: var(--text-muted);
		font-size: 1.1rem;
	}

	/* Filters */
	.pokedex-filters {
		display: flex;
		justify-content: center;
		margin-bottom: 2rem;
	}

	.type-filter-buttons {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.5rem;
		max-width: 900px;
	}

	.type-btn {
		padding: 0.4rem 1rem;
		border-radius: 20px;
		border: 2px solid transparent;
		color: white;
		font-weight: 700;
		font-size: 0.85rem;
		text-transform: uppercase;
		cursor: pointer;
		opacity: 0.6;
		transition: all 0.2s;
		text-shadow: 0 1px 2px rgba(0, 0, 0, 0.8);
	}

	.type-btn[data-type="all"] {
		background-color: var(--surface-color-light);
		border: 1px solid var(--glass-border);
		color: white;
	}

	.type-btn:hover {
		opacity: 0.9;
		transform: scale(1.05);
	}

	.type-btn.active {
		opacity: 1;
		border-color: white;
		transform: scale(1.05);
		box-shadow: 0 4px 10px rgba(0, 0, 0, 0.4);
	}
</style>
