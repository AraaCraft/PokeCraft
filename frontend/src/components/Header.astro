---
---
<header class="global-header glass-panel">
  <div class="header-content">
    <a href={import.meta.env.BASE_URL} class="logo">
      <img src={`${import.meta.env.BASE_URL}favicon.svg`} alt="PokeCraft Logo" style="height: 32px; width: 32px; margin-right: 8px;" />
      <span class="poke">Poke</span><span class="craft">Craft</span>
    </a>
    
    <div class="header-actions">
      <!-- Desktop Search -->
      <div class="search-container desktop-only">
        <div class="search-input-wrapper">
          <span class="search-icon">🔍</span>
          <input type="text" id="desktop-search" data-i18n="search_placeholder" placeholder="Search for a Pokémon..." autocomplete="off" />
        </div>
        <ul id="desktop-search-results" class="search-results hidden">
          <!-- Populated by JS -->
        </ul>
      </div>

      <!-- Mobile Search Trigger -->
      <button id="open-search-modal" class="search-trigger-btn mobile-only">
        <span class="search-icon">🔍</span>
      </button>

      <nav class="header-nav">
        <a href={`${import.meta.env.BASE_URL}types`} class="nav-link"><span data-i18n="type_chart">Type Chart</span></a>
      </nav>

      <a href={`${import.meta.env.BASE_URL}team`} class="team-link"><span data-i18n="my_team">My Team</span> (<span id="team-count">0</span>)</a>
      <div class="lang-selector-container">
        <select class="lang-selector" id="lang-selector">
          <option value="en">EN</option>
          <option value="fr">FR</option>
        </select>
      </div>
    </div>
  </div>
</header>

<!-- Search Modal -->
<div id="search-modal" class="search-modal-overlay hidden">
  <div class="search-modal-content glass-panel">
    <div class="search-modal-header">
      <div class="search-input-wrapper">
        <span class="search-icon-large">🔍</span>
        <input type="text" id="mobile-search" data-i18n="search_placeholder" placeholder="Search for a Pokémon..." autocomplete="off" />
      </div>
      <button id="close-search-modal" class="close-modal-btn">✕</button>
    </div>
    <ul id="mobile-search-results" class="search-results-modal">
      <!-- Populated by JS -->
      <li style="padding: 1rem; color: #a0a0a0; text-align: center; font-size: 0.9rem;" data-i18n="search_hint">Start typing to search...</li>
    </ul>
  </div>
</div>

<style>
  .global-header {
    position: sticky;
    top: 0;
    z-index: 1000;
    margin-bottom: 2rem;
    padding: 1rem 0;
    /* Extra blur for a true glassmorphism header */
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border-bottom: 1px solid var(--glass-border);
    border-radius: 0 0 16px 16px;
  }

  .header-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .logo {
    font-size: 1.8rem;
    font-weight: 800;
    text-decoration: none;
    letter-spacing: -0.5px;
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .poke {
    color: white;
  }

  .craft {
    color: var(--primary-color, #ff5350);
  }

  .logo:hover {
    opacity: 0.9;
  }

  /* --- Actions Block --- */
  .header-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex: 1;
    justify-content: flex-end;
  }

  /* Search Bar */
  .header-nav {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-right: 1rem;
  }

  .nav-link {
    color: white;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    transition: color 0.2s;
  }

  .nav-link:hover {
    color: var(--primary-color, #ff5350);
  }

  .desktop-only {
    display: block !important;
  }
  .mobile-only {
    display: none !important;
  }

  .search-container {
    position: relative;
    max-width: 300px;
    width: 100%;
  }

  .search-input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
  }

  .search-icon {
    position: absolute;
    left: 16px;
    font-size: 1.1rem;
    pointer-events: none;
    opacity: 0.6;
  }

  #desktop-search {
    background: var(--surface-color-light);
    border: 1px solid var(--glass-border);
    border-radius: 24px;
    padding: 0.6rem 1.2rem 0.6rem 2.8rem;
    color: white;
    font-family: inherit;
    font-size: 0.95rem;
    width: 100%;
    transition: all 0.3s ease;
    outline: none;
    box-shadow: inset 0 2px 4px rgba(0,0,0,0.2);
  }

  #desktop-search:focus {
    background: var(--surface-color);
    border-color: var(--primary-color, #ff5350);
    box-shadow: 0 0 0 3px rgba(255, 83, 80, 0.2), inset 0 2px 4px rgba(0,0,0,0.2);
  }

  #desktop-search::placeholder {
    color: var(--text-muted);
  }

  /* Search Results Dropdown */
  .search-results {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    margin-top: 0.5rem;
    background: #1a1c1e;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.8);
    list-style: none;
    padding: 0.5rem 0;
    max-height: 400px;
    overflow-y: auto;
    z-index: 1001;
    transition: opacity 0.2s, visibility 0.2s, transform 0.2s;
    transform: translateY(0);
  }

  .search-results.hidden {
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    pointer-events: none;
  }

  /* Search Trigger Button (Mobile) */
  .search-trigger-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--surface-color-light);
    border: 1px solid var(--glass-border);
    border-radius: 50%;
    width: 40px;
    height: 40px;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .search-trigger-btn:hover {
    background: var(--surface-color);
    border-color: rgba(255, 255, 255, 0.3);
  }

  .search-trigger-btn .search-icon {
    position: static;
    opacity: 1;
  }

  /* Search Modal */
  .search-modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
    z-index: 2000;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding-top: 10vh;
    opacity: 1;
    visibility: visible;
    transition: opacity 0.2s, visibility 0.2s;
  }

  .search-modal-overlay.hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .search-modal-content {
    width: 90%;
    max-width: 600px;
    background: #1a1c1e;
    border-radius: 16px;
    border: 1px solid var(--glass-border);
    box-shadow: 0 20px 40px rgba(0,0,0,0.5);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transform: translateY(0);
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .search-modal-overlay.hidden .search-modal-content {
    transform: translateY(-20px) scale(0.95);
  }

  .search-modal-header {
    display: flex;
    align-items: center;
    padding: 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }

  .search-input-wrapper {
    flex: 1;
    display: flex;
    align-items: center;
    position: relative;
  }

  .search-icon-large {
    position: absolute;
    left: 12px;
    font-size: 1.2rem;
    opacity: 0.6;
    pointer-events: none;
  }

  #mobile-search {
    width: 100%;
    background: transparent;
    border: none;
    color: white;
    font-family: inherit;
    font-size: 1.2rem;
    padding: 0.5rem 1rem 0.5rem 3rem;
    outline: none;
  }

  #mobile-search::placeholder {
    color: var(--text-muted);
  }

  .close-modal-btn {
    background: transparent;
    border: none;
    color: var(--text-muted);
    font-size: 1.2rem;
    cursor: pointer;
    padding: 0.5rem;
    transition: color 0.2s;
  }

  .close-modal-btn:hover {
    color: white;
  }

  /* Search Results in Modal */
  .search-results-modal {
    list-style: none;
    padding: 0;
    margin: 0;
    max-height: 50vh;
    overflow-y: auto;
  }

  :global(.search-result-item) {
    padding: 0;
  }

  :global(.search-result-link) {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0.6rem 1rem;
    color: var(--text-color, #e0e0e0);
    text-decoration: none;
    transition: background 0.2s;
  }

  :global(.search-result-link:hover) {
    background: rgba(255, 255, 255, 0.08);
  }

  :global(.search-result-link.selected) {
    background: rgba(255, 255, 255, 0.15);
  }

  :global(.search-result-id) {
    font-size: 0.8rem;
    color: var(--text-muted, #a0a0a0);
    font-family: monospace;
    background: rgba(0,0,0,0.3);
    padding: 2px 6px;
    border-radius: 4px;
  }

  :global(.search-result-name) {
    font-weight: 600;
  }

  /* Lang Selector */
  .lang-selector {
    background: var(--surface-color-light);
    color: white;
    border: 1px solid var(--glass-border);
    padding: 0.7rem 1.2rem;
    border-radius: 12px;
    font-family: inherit;
    font-size: 1rem;
    outline: none;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.2s ease;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
  }

  .lang-selector:hover {
    border-color: rgba(255, 255, 255, 0.3);
    background: var(--surface-color);
  }

  .team-link {
    color: white;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    padding: 0.5rem 1rem;
    background: rgba(255, 83, 80, 0.2);
    border: 1px solid var(--primary-color, #ff5350);
    border-radius: 20px;
    transition: all 0.2s;
  }

  .team-link:hover {
    background: var(--primary-color, #ff5350);
  }

  @media (max-width: 768px) {
    .header-content {
      flex-direction: column;
    }
    .desktop-only {
      display: none !important;
    }
    .mobile-only {
      display: flex !important;
    }
  }
</style>

<script>
  import { getActiveTeam } from '../scripts/teamStore.js';
  import { getLang, setLang } from '../scripts/langStore.js';

  let searchIndex = [];
  const desktopSearch = document.getElementById('desktop-search') as HTMLInputElement;
  const desktopResults = document.getElementById('desktop-search-results');
  
  const mobileSearch = document.getElementById('mobile-search') as HTMLInputElement;
  const mobileResults = document.getElementById('mobile-search-results');

  const langSelector = document.getElementById('lang-selector') as HTMLSelectElement;
  const teamCountEl = document.getElementById('team-count');

  // Update team count
  function updateTeamCount() {
    if (teamCountEl) {
      const activeTeam = getActiveTeam();
      teamCountEl.textContent = activeTeam.members.length.toString();
    }
  }
  
  updateTeamCount();
  window.addEventListener('storage', updateTeamCount);
  setInterval(updateTeamCount, 1000);
  window.addEventListener('team-data-updated', updateTeamCount);

  // Load search index
  async function loadSearchIndex() {
    try {
      const res = await fetch(import.meta.env.BASE_URL + 'data/search_index.json');
      if (res.ok) {
        searchIndex = await res.json();
      }
    } catch (e) {
      console.error("Failed to load search index", e);
    }
  }

  loadSearchIndex();

  function renderResults(query, resultsContainer) {
    if (!query) {
      resultsContainer.classList.add('hidden');
      return;
    }

    const q = query.toLowerCase().trim();
    const currentLang = getLang();
    
    // Filter matches
    const matches = searchIndex.filter(p => {
      if (p.name_en && p.name_en.toLowerCase().includes(q)) return true;
      if (p.name_fr && p.name_fr.toLowerCase().includes(q)) return true;
      if (String(p.id).includes(q)) return true;
      if (p.forms && p.forms.some(f => f.toLowerCase().includes(q))) return true;
      return false;
    }).slice(0, 10);

    if (matches.length === 0) {
      resultsContainer.innerHTML = '<li style="padding: 1rem; color: #a0a0a0; text-align: center; font-size: 0.9rem;">No Pokémon found</li>';
      resultsContainer.classList.remove('hidden');
      return;
    }

    resultsContainer.innerHTML = matches.map(p => {
      const formattedId = String(p.id).padStart(4, '0');
      let displayName = currentLang === 'fr' ? (p.name_fr || p.name_en) : (p.name_en || p.name);
      
      return `
        <li class="search-result-item">
          <a href="${import.meta.env.BASE_URL}pokemon/${p.id}-${p.base_form}" class="search-result-link">
            <span class="search-result-id">#${formattedId}</span>
            <span class="search-result-name">${displayName}</span>
          </a>
        </li>
      `;
    }).join('');

    resultsContainer.classList.remove('hidden');
  }

  // Desktop Events
  if (desktopSearch) {
    desktopSearch.addEventListener('input', (e) => {
      renderResults((e.target as HTMLInputElement).value, desktopResults);
    });

    document.addEventListener('click', (e) => {
      if (!desktopSearch.contains(e.target as Node) && !desktopResults.contains(e.target as Node)) {
        desktopResults.classList.add('hidden');
      }
    });

    desktopSearch.addEventListener('focus', () => {
      if (desktopSearch.value) {
        desktopResults.classList.remove('hidden');
      }
    });
  }

  // Mobile Events
  if (mobileSearch) {
    mobileSearch.addEventListener('input', (e) => {
      renderResults((e.target as HTMLInputElement).value, mobileResults);
    });
  }

  // Keyboard Navigation
  function setupKeyboardNav(input, container) {
    if (!input || !container) return;
    
    input.addEventListener('keydown', (e) => {
      if (container.classList.contains('hidden')) return;
      
      const items = Array.from(container.querySelectorAll('.search-result-link')) as HTMLElement[];
      if (items.length === 0) return;
      
      const currentIndex = items.findIndex(item => item.classList.contains('selected'));
      
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        const nextIndex = currentIndex < items.length - 1 ? currentIndex + 1 : 0;
        items.forEach(item => item.classList.remove('selected'));
        items[nextIndex].classList.add('selected');
        items[nextIndex].scrollIntoView({ block: 'nearest' });
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        const nextIndex = currentIndex > 0 ? currentIndex - 1 : items.length - 1;
        items.forEach(item => item.classList.remove('selected'));
        items[nextIndex].classList.add('selected');
        items[nextIndex].scrollIntoView({ block: 'nearest' });
      } else if (e.key === 'Enter') {
        e.preventDefault();
        if (currentIndex >= 0) {
          items[currentIndex].click();
        } else if (items.length > 0) {
          items[0].click();
        }
      }
    });
  }

  setupKeyboardNav(desktopSearch, desktopResults);
  setupKeyboardNav(mobileSearch, mobileResults);

  // Modal logic
  const searchModal = document.getElementById('search-modal');
  const openSearchBtn = document.getElementById('open-search-modal');
  const closeSearchBtn = document.getElementById('close-search-modal');

  function openModal() {
    if (searchModal) {
      searchModal.classList.remove('hidden');
      if (mobileSearch) setTimeout(() => mobileSearch.focus(), 100);
      document.body.style.overflow = 'hidden';
    }
  }

  function closeModal() {
    if (searchModal) {
      searchModal.classList.add('hidden');
      document.body.style.overflow = '';
    }
  }

  if (openSearchBtn) openSearchBtn.addEventListener('click', openModal);
  if (closeSearchBtn) closeSearchBtn.addEventListener('click', closeModal);

  // Close on outside click
  if (searchModal) {
    searchModal.addEventListener('click', (e) => {
      if (e.target === searchModal) closeModal();
    });
  }

  // Keyboard shortcuts
  document.addEventListener('keydown', (e) => {
    // Escape to close
    if (e.key === 'Escape' && searchModal && !searchModal.classList.contains('hidden')) {
      closeModal();
    }
    // Cmd+K or Ctrl+K to open
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      openModal();
    }
  });

  // Basic Lang selector persistence
  if (langSelector) {
    langSelector.value = getLang();
    
    langSelector.addEventListener('change', (e) => {
      setLang((e.target as HTMLSelectElement).value);
      // Re-render search results if open
      if (desktopSearch && desktopSearch.value) renderResults(desktopSearch.value, desktopResults);
      if (mobileSearch && mobileSearch.value) renderResults(mobileSearch.value, mobileResults);
    });
  }
</script>
